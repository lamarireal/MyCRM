# Application
MYCRM_APP_ENV=local
MYCRM_LOG_LEVEL=INFO
MYCRM_API_HOST=0.0.0.0
MYCRM_API_PORT=8000
MYCRM_CORS_ORIGINS=["http://localhost:5173"]

# PostgreSQL
POSTGRES_DB=mycrm
POSTGRES_USER=mycrm
POSTGRES_PASSWORD=change-me
MYCRM_DATABASE_URL=postgresql+asyncpg://mycrm:change-me@localhost:5432/mycrm

# Frontend (leave empty when Vite proxy is used)
VITE_API_URL=
