# Application
MYCRM_APP_ENV=local
MYCRM_LOG_LEVEL=INFO
MYCRM_API_HOST=0.0.0.0
MYCRM_API_PORT=8000
MYCRM_CORS_ORIGINS=["http://localhost:5173"]
MYCRM_ALLOWED_HOSTS=["localhost","127.0.0.1","test"]
MYCRM_ENABLE_DOCS=true
MYCRM_SECRET_KEY=local-development-key-only
MYCRM_MAX_REQUEST_BODY_BYTES=1048576
MYCRM_PUBLIC_RATE_LIMIT_PER_MINUTE=120
MYCRM_DEMO_ENABLED=false
MYCRM_DEMO_READ_ONLY=true
MYCRM_DEMO_WORKSPACE_SLUG=public-demo

# PostgreSQL
POSTGRES_DB=mycrm
POSTGRES_USER=mycrm
POSTGRES_PASSWORD=change-me
MYCRM_DATABASE_URL=postgresql+asyncpg://mycrm:change-me@localhost:5432/mycrm

# Frontend (leave empty when Vite proxy is used)
VITE_API_URL=
